{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fast-copy",
  "version": "0.2.4",
  "identifier": "com.bistiti.fastcopy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fast-copy",
        "width": 1100,
        "height": 700,
        "minWidth": 820,
        "minHeight": 540,
        "dragDropEnabled": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
